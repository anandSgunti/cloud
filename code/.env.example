# Azure Storage connection string (Table + Blob)
CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your_account>;AccountKey=<your_key>;EndpointSuffix=core.windows.net

# Azure Face API (Cognitive Services)
FACE_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
FACE_API_KEY=<your_face_api_key>
